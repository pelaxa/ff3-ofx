{
  "name": "ff3-ofx",
  "version": "2.0.1",
  "homepage": "./",
  "private": true,
  "type": "module",
  "licenses": [
    {
      "name": "GPL-3.0-or-later",
      "url": "https://www.gnu.org/licenses/gpl-3.0-standalone.html",
      "text": "Copyright (c) 2026"
    }
  ],
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@billos/firefly-iii-sdk": "^6.5.5-sdk.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "axios": "^1.16.1",
    "moment": "^2.30.1",
    "mui-file-dropzone": "^4.0.2",
    "node-ofx-parser": "^0.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite preview",
    "compile": "tsc -b && vite build",
    "dist": "cross-os dist",
    "package": "rm -rf ./dist/* ; yarn lint && yarn test && yarn compile && yarn dist",
    "test": "vitest run --coverage",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf ./node_modules; rm -rf dist; yarn install"
  },
  "cross-os": {
    "dist": {
      "darwin": "rm -f ./dist/*.gz ; tar -s \"/^dist/ff3-ofx/\" -cvzf dist/ff3-ofx-${npm_package_version}.tar.gz dist/*",
      "win32": "echo Windows is not currently supported!",
      "linux": "rm -f ./dist/*.gz ; tar --transform 's|^dist|ff3-ofx|' -cvzf dist/ff3-ofx-${npm_package_version}.tar.gz dist/*"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@rollup/plugin-json": "^6.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/http-proxy": "^1.17.17",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-os": "^1.5.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.0.0",
    "http-proxy": "^1.18.1",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.7",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.13.0"
}
